# Caddy config for ClimaNexus landing — explicit byte-range support for video streaming
:{$PORT} {
	root * .

	# Headers for ALL responses
	header {
		# Critical for mobile video streaming
		Accept-Ranges bytes
		# Security
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Video files: long cache + ensure byte-range
	@videos {
		path /videos/* /videos/posters/*
	}
	header @videos {
		Cache-Control "public, max-age=2592000, immutable"
		Accept-Ranges bytes
	}

	# Audio files: long cache + ensure byte-range (critical for streaming)
	@audio {
		path /audio/*
	}
	header @audio {
		Cache-Control "public, max-age=2592000, immutable"
		Accept-Ranges bytes
	}

	# Image files: long cache
	@images {
		path /images/* *.png *.jpg *.jpeg *.svg *.webp
	}
	header @images Cache-Control "public, max-age=2592000, immutable"

	# Demo route → demo.html
	@demoExact path /demo
	rewrite @demoExact /demo.html

	# Static file server with byte-range support
	file_server {
		precompressed gzip br
	}

	# Fallback to index.html for SPA-style routes (none currently, but safe)
	try_files {path} {path}/ /index.html

	encode gzip zstd
}
