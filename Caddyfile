# Caddy config for ClimaNexus landing
# Videos served by Cloudflare Stream (https://customer-iiya2h68v5nrm40u.cloudflarestream.com)
# Audio + Images served from this server
:{$PORT} {
	root * .

	# Headers for ALL responses
	header {
		Accept-Ranges bytes
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}

	# Audio files: long cache + ensure byte-range (for ambient music streaming)
	@audio {
		path /audio/*
	}
	header @audio {
		Cache-Control "public, max-age=2592000, immutable"
		Accept-Ranges bytes
	}

	# Image files: long cache
	@images {
		path /images/* *.png *.jpg *.jpeg *.svg *.webp *.ico
	}
	header @images Cache-Control "public, max-age=2592000, immutable"

	# Demo route → demo.html
	@demoExact path /demo
	rewrite @demoExact /demo.html

	# Static file server
	file_server {
		precompressed gzip br
	}

	try_files {path} {path}/ /index.html

	encode gzip zstd
}
